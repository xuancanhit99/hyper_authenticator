<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.hyperz.hyper-authenticator.supabase-backup</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>__HOME__/Library/Application Support/Hyper Authenticator/ops/pull_encrypted_backup.sh</string>
  </array>
  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    <key>OPERATOR_ENV</key>
    <string>__OPERATOR_ENV__</string>
    <key>AGE_RECIPIENT_FILE</key>
    <string>__HOME__/.config/hyper-authenticator/supabase-backup-age-recipient.txt</string>
    <key>AGE_IDENTITY_FILE</key>
    <string>__HOME__/.config/hyper-authenticator/supabase-backup-age-key.txt</string>
    <key>DESTINATION_ROOT</key>
    <string>__HOME__/Backups/hyper_authenticator/supabase-production-encrypted</string>
  </dict>
  <key>RunAtLoad</key>
  <true/>
  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key>
    <integer>10</integer>
    <key>Minute</key>
    <integer>15</integer>
  </dict>
  <key>ProcessType</key>
  <string>Background</string>
  <key>ThrottleInterval</key>
  <integer>300</integer>
  <key>StandardOutPath</key>
  <string>__HOME__/Library/Logs/Hyper Authenticator/supabase-backup.log</string>
  <key>StandardErrorPath</key>
  <string>__HOME__/Library/Logs/Hyper Authenticator/supabase-backup-error.log</string>
</dict>
</plist>
